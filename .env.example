# Paycrest API Configuration
PAYCREST_API_KEY=your_paycrest_api_key_here
PAYCREST_WEBHOOK_SECRET=your_paycrest_webhook_secret_here

# Base Network Configuration (Server-side only - NEVER use NEXT_PUBLIC_)
